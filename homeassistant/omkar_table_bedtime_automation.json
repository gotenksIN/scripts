{
  "alias": "Omkar Table Bedtime Auto",
  "description": "At 10:30 PM, dim table lights to 20% when either phone is home, but only if the light is already on.",
  "trigger": [
    {
      "platform": "time",
      "at": "22:30:00"
    }
  ],
  "condition": [
    {
      "condition": "or",
      "conditions": [
        { "condition": "state", "entity_id": "binary_sensor.192_168_0_122", "state": "on" },
        { "condition": "state", "entity_id": "binary_sensor.192_168_0_121", "state": "on" }
      ]
    },
    {
      "condition": "state",
      "entity_id": "light.table",
      "state": "on"
    }
  ],
  "action": [
    {
      "action": "script.turn_on",
      "target": { "entity_id": "script.omkar_table_bedtime" }
    }
  ],
  "mode": "single"
}
