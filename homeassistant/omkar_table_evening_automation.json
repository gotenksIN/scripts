{
  "alias": "Omkar Table Evening Auto",
  "description": "When sun elevation drops below 8, set table lights to 60% at 5000K when either phone is home.",
  "triggers": [
    {
      "platform": "numeric_state",
      "entity_id": "sun.sun",
      "attribute": "elevation",
      "below": 8,
      "for": "00:05:00"
    },
    {
      "platform": "homeassistant",
      "event": "start"
    }
  ],
  "conditions": [
    {
      "condition": "state",
      "entity_id": "light.table",
      "state": "off"
    },
    {
      "condition": "template",
      "value_template": "{% set elevation = state_attr('sun.sun', 'elevation') | float(90) %}{{ elevation > 0 and elevation < 8 and not state_attr('sun.sun', 'rising') }}"
    },
    {
      "condition": "or",
      "conditions": [
        { "condition": "state", "entity_id": "device_tracker.rtwobox", "state": "home" },
        { "condition": "state", "entity_id": "device_tracker.oneplusbox", "state": "home" }
      ]
    }
  ],
  "actions": [
    {
      "action": "script.turn_on",
      "target": { "entity_id": "script.omkar_table_evening" }
    }
  ],
  "mode": "single"
}