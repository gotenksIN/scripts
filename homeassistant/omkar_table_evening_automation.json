{
  "alias": "Omkar Table Evening Auto",
  "description": "When sun elevation drops below 5, set table lights to 60% at 5000K when either phone is home.",
  "trigger": [
    {
      "platform": "numeric_state",
      "entity_id": "sun.sun",
      "attribute": "elevation",
      "below": 5
    }
  ],
  "condition": [
    {
      "condition": "or",
      "conditions": [
        { "condition": "state", "entity_id": "device_tracker.marblebox_2", "state": "home" },
        { "condition": "state", "entity_id": "device_tracker.oneplusbox_2", "state": "home" }
      ]
    }
  ],
  "action": [
    {
      "action": "script.turn_on",
      "target": { "entity_id": "script.omkar_table_evening" }
    }
  ],
  "mode": "single"
}
