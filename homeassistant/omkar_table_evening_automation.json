{
  "alias": "Omkar Table Evening Auto",
  "description": "When sun elevation drops below -2.0°, set table lights to 60% at 5000K when either phone is home and on SkyNet.",
  "trigger": [
    {
      "platform": "numeric_state",
      "entity_id": "sun.sun",
      "attribute": "elevation",
      "below": -2.0
    }
  ],
  "condition": [
    {
      "condition": "or",
      "conditions": [
        {
          "condition": "and",
          "conditions": [
            { "condition": "state", "entity_id": "device_tracker.marblebox", "state": "home" },
            { "condition": "state", "entity_id": "sensor.marblebox_wi_fi_connection", "state": "SkyNet" }
          ]
        },
        {
          "condition": "and",
          "conditions": [
            { "condition": "state", "entity_id": "device_tracker.oneplusbox", "state": "home" },
            { "condition": "state", "entity_id": "sensor.oneplusbox_wi_fi_connection", "state": "SkyNet" }
          ]
        }
      ]
    }
  ],
  "action": [
    {
      "action": "script.turn_on",
      "target": { "entity_id": "script.omkar_table_evening" }
    }
  ],
  "mode": "single"
}
