{
  "alias": "Omkar Table Sunset Auto",
  "description": "When sun elevation drops below -4°, set table lights to 40% at 2200K when either phone is home.",
  "trigger": [
    {
      "platform": "numeric_state",
      "entity_id": "sun.sun",
      "attribute": "elevation",
      "below": -4
    }
  ],
  "condition": [
    {
      "condition": "or",
      "conditions": [
        { "condition": "state", "entity_id": "device_tracker.nothingbox_2", "state": "home" },
        { "condition": "state", "entity_id": "device_tracker.oneplusbox_2", "state": "home" }
      ]
    }
  ],
  "action": [
    {
      "action": "script.turn_on",
      "target": { "entity_id": "script.omkar_table_sunset" }
    }
  ],
  "mode": "single"
}
